VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
VITE_FIREBASE_APPCHECK_SITE_KEY=your-recaptcha-v3-site-key
# Optional para desarrollo local con App Check debug:
# VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=your-debug-token

# Optional para scripts/admin:
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_SERVICE_ACCOUNT_PATH=./scripts/serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
